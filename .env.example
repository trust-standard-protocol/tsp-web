# Copy to .env at deploy time. NEVER commit .env. No secrets live in this repo.
# Fase A has no backend and no database — the only value needed is the ACME email
# Caddy uses to obtain Let's Encrypt certificates.

ACME_EMAIL=ops@truststandardprotocol.com

# Reminder (see DEPLOY.md): provision a NEW SSH deploy key for the host.
# NEVER reuse the old tsp-site-hel1-cloud-init.yaml key — treat it as compromised.
