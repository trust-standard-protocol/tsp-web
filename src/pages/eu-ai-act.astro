---
import BaseLayout from "../layouts/BaseLayout.astro";
import Boundary from "../components/Boundary.astro";

interface Row {
  article: string;
  title: string;
  evidence: string;
  boundary: string;
}

const rows: Row[] = [
  {
    article: "Art 12 · logging",
    title: "Record-keeping",
    evidence: "Signed event receipts — answer, action, refusal, review, override — chained, hashed and timestamped across the workflow.",
    boundary: "Evidence of what happened; not a compliance verdict."
  },
  {
    article: "Art 14",
    title: "Human oversight",
    evidence: "Signed human-review and override receipts record who reviewed, what they decided, and when — sealed inside the digest.",
    boundary: "Shows oversight occurred; not that it was sufficient."
  },
  {
    article: "Art 15",
    title: "Accuracy records",
    evidence: "Declared model, tool, data-scope and policy state captured in tamper-evident receipts.",
    boundary: "Evidence of declared state; not model quality."
  },
  {
    article: "Art 19",
    title: "Logs retention",
    evidence: "An append-only, independently checkable feed of receipts an operator can retain and reproduce on request.",
    boundary: "Durable, reproducible evidence; retention duration is the operator's policy call."
  },
  {
    article: "Art 50",
    title: "Transparency",
    evidence: "A TrustBadge and evidence view link an AI output to its provenance receipt for disclosure.",
    boundary: "Supports disclosure; not a labelling decision."
  },
  {
    article: "Annex III · Art 6",
    title: "High-risk support",
    evidence: "Portable receipts for decision-support workflows (e.g. creditworthiness) an assessor can inspect.",
    boundary: "Input to classification; not the classification answer."
  }
];
---
<BaseLayout
  title="EU AI Act"
  description="How signed TSP receipts support EU AI Act obligations — Art 12, 14, 15, 19, 50 and Annex III — as inspectable evidence, not a legal verdict."
>
  <section class="section section--tight">
    <div class="container">
      <p class="eyebrow">EU AI Act · evidence mapping</p>
      <h1>Where signed receipts support the obligations</h1>
      <p class="lede">TSP produces inspectable evidence for the runtime behaviour the AI Act asks teams to
        record. It is an <strong>evidence input</strong> — it does not classify a system or settle a legal
        outcome.</p>
    </div>
  </section>

  <section class="section--tight" style="padding-top:0">
    <div class="container stack">
      {rows.map((row) => (
        <article class="card">
          <div class="split" style="align-items:start">
            <div>
              <span class="chip chip--teal">{row.article}</span>
              <h3 style="margin-top:0.6rem">{row.title}</h3>
              <p class="muted">{row.evidence}</p>
            </div>
            <p class="boundary" style="margin:0"><strong>Boundary:</strong> {row.boundary}</p>
          </div>
        </article>
      ))}
      <Boundary />
      <p class="muted" style="font-size:var(--fs-small)">
        Article references are pointers to where TSP evidence is useful; they are not legal advice. Confirm
        applicability and dates with your DPA and counsel before relying on them. See the obligations in
        action in the <a href="/playground/">playground</a>.
      </p>
    </div>
  </section>
</BaseLayout>
