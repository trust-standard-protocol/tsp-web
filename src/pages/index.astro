---
import BaseLayout from "../layouts/BaseLayout.astro";
import Boundary from "../components/Boundary.astro";
import { site } from "../data/site";
---
<BaseLayout title={site.name} description={site.description}>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Trust Standard Protocol</p>
      <h1>Prove what your AI decided — and let anyone check that nothing changed.</h1>
      <p class="lede">
        Every AI-mediated decision gets a sealed, signed receipt. Anyone can verify it offline — without
        trusting you, your vendor, or each other. Change a single byte and verification fails.
      </p>
      <div class="btn-row" style="margin-top:1.6rem">
        <a class="btn btn-primary" href="/playground/">See a receipt break live →</a>
        <a class="btn btn-ghost" href="/verify/">Verify a receipt</a>
      </div>
      <pre style="margin-top:1.6rem; max-width:620px"><code>$ npx @trust-standard-protocol/cli verify receipt.json --offline
&#10003; schema   &#10003; content hash   &#10003; ledger hash   &#10003; ed25519 signature
&rarr; VERIFIED &middot; evidence integrity only — not a legal verdict</code></pre>
      <div style="margin-top:1.6rem; max-width:62ch"><Boundary /></div>
    </div>
  </section>

  <!-- Three steps -->
  <section class="section section--paper-deep">
    <div class="container">
      <p class="eyebrow">The whole idea</p>
      <h2>Three steps. Nothing you can't inspect.</h2>
      <div class="grid grid-3" style="margin-top:2rem">
        <article class="card card--accent">
          <p class="mono muted" style="font-size:var(--fs-micro)">01</p>
          <h3>It gets sealed</h3>
          <p class="muted">The moment the AI decides, the event is captured and hashed into a signed,
            tamper-evident receipt. Change one detail later and the seal breaks.</p>
        </article>
        <article class="card card--accent">
          <p class="mono muted" style="font-size:var(--fs-micro)">02</p>
          <h3>It gets published</h3>
          <p class="muted">The receipt joins a public, append-only chain — each one links to the hash of
            the one before it. Everyone sees it exists; no private data is exposed.</p>
        </article>
        <article class="card card--teal">
          <p class="mono muted" style="font-size:var(--fs-micro)">03</p>
          <h3>Anyone verifies</h3>
          <p class="muted">Re-run the cryptography yourself against the issuer's public key. Pass or fail,
            you get the same answer as everyone else — forever, with no login and no permission.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Live tamper band -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Live · runs in your browser</p>
      <h2>Change one byte and watch the cryptography reject it.</h2>
      <p class="lede">This is the real verifier — the same Ed25519 + JCS + TrustEnvelope v3 code that ships in
        the SDK — running against a real receipt right here. Nothing is uploaded.</p>

      <div id="tamper-band" class="panel" style="margin-top:1.5rem">
        <div class="panel__head">
          <span>receipt.json · live verify</span>
          <span class="chip chip--teal">offline · real Ed25519</span>
        </div>
        <div class="panel__body">
          <div class="split">
            <pre id="tb-json" style="margin:0; max-height:320px"></pre>
            <div class="stack">
              <div id="tb-verdict" class="verdict" data-state="idle">Verifying…</div>
              <div id="tb-checks" class="checks"></div>
              <div class="btn-row">
                <button id="tb-verify" class="btn btn-quiet" type="button">Re-verify</button>
                <button id="tb-tamper" class="btn btn-ghost" type="button">⚡ Break one byte</button>
                <button id="tb-reset" class="btn btn-quiet" type="button">Reset</button>
                <a class="btn btn-primary" href="/playground/">Build a full chain →</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EU AI Act strip -->
  <section class="section section--ground">
    <div class="container">
      <p class="eyebrow">EU AI Act · evidence, not a verdict</p>
      <h2>Signed receipts map to the obligations teams must record.</h2>
      <div class="grid grid-3" style="margin-top:2rem">
        <div class="card" style="background:transparent; border-color:rgba(244,239,226,.22)">
          <h3 style="color:var(--ink-inverse)">Art 12 — Record-keeping</h3>
          <p style="color:var(--ink-inverse-muted)">Chained, hashed, timestamped event receipts across the
            workflow. Evidence of what happened — not a compliance verdict.</p>
        </div>
        <div class="card" style="background:transparent; border-color:rgba(244,239,226,.22)">
          <h3 style="color:var(--ink-inverse)">Art 14 — Human oversight</h3>
          <p style="color:var(--ink-inverse-muted)">A signed human-review field, sealed inside the digest.
            Shows oversight occurred — not that it was sufficient.</p>
        </div>
        <div class="card" style="background:transparent; border-color:rgba(244,239,226,.22)">
          <h3 style="color:var(--ink-inverse)">Art 50 — Transparency</h3>
          <p style="color:var(--ink-inverse-muted)">A TrustBadge links an AI output to its provenance receipt
            for disclosure. Supports disclosure — not a labelling decision.</p>
        </div>
      </div>
      <p style="margin-top:1.5rem"><a href="/eu-ai-act/">See the full Art 12 / 14 / 15 / 19 / 50 mapping →</a></p>
    </div>
  </section>

  <!-- Open vs seal -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Open layer vs. the seal</p>
      <h2>Free to verify · licensed to issue · controlled to be official.</h2>
      <div class="grid grid-3" style="margin-top:2rem">
        <article class="card">
          <span class="chip chip--ok">Free, forever</span>
          <h3 style="margin-top:0.6rem">Verify &amp; inspect</h3>
          <p class="muted">The verifier cores, the MCP server/proxy, the TrustBadge component and the spec are
            open (Apache-2.0). Offline verification always works — no phone-home, no kill switch.</p>
        </article>
        <article class="card card--accent">
          <span class="chip chip--copper">Licensed</span>
          <h3 style="margin-top:0.6rem">Issue &amp; operate</h3>
          <p class="muted">Issuer tooling, runtime, gateway and the commercial modules (pilot / staging) sit
            behind a commercial TSP license. One signer; the open verifiers do the rest.</p>
        </article>
        <article class="card card--teal">
          <span class="chip chip--teal">Governed</span>
          <h3 style="margin-top:0.6rem">Official status</h3>
          <p class="muted">Issuer authorization, registry listing and official mark usage are governed grants —
            never unlocked by payment. Payment never grants official status.</p>
        </article>
      </div>
      <p style="margin-top:1.5rem"><a href="/pricing/">See pricing &amp; tiers →</a> &nbsp;·&nbsp; <a href="/tools/">Browse the tools →</a></p>
    </div>
  </section>

  <!-- Standing challenge -->
  <section class="section section--paper-deep">
    <div class="container split">
      <div>
        <p class="eyebrow">The standing challenge</p>
        <h2>We bet the product on the math.</h2>
        <p class="muted">Forge a receipt that passes independent verification — alter the data and still come up
          VERIFIED — and you keep every priced module, free for life, plus a place in the registry's hall of
          integrity. Break the math, not the building (key theft and server breaches are out of scope).</p>
      </div>
      <div class="card" style="align-self:center">
        <p class="mono muted" style="font-size:var(--fs-micro)">breaks to date</p>
        <p style="font-size:3rem; font-weight:600; line-height:1; color:var(--teal)">0</p>
        <p class="muted" style="font-size:var(--fs-small)">It's a marketing bet, not a claim — the protocol is
          a pilot, and the cryptography is the part we're sure of.</p>
        <p style="margin-top:0.8rem"><a href="/hard-questions/">Read the hard questions →</a></p>
      </div>
    </div>
  </section>

  <!-- Leaderboard teaser -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Adoption leaderboard</p>
      <h2>Ranked by evidence — not size, not spend.</h2>
      <p class="lede">Every score is recomputed from an organization's own published receipts:
        Verifiability (0.40), Coverage (0.35), Human oversight (0.25). You can't buy a place, only evidence one.</p>
      <p style="margin-top:1rem"><a class="btn btn-ghost" href="/leaderboard/">See how scoring works &amp; get listed →</a></p>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section section--ground">
    <div class="container">
      <h2>Make your AI decisions checkable.</h2>
      <p class="lede">Start with one decision flow. We scope a single workflow with you and wire it into one
        evidence chain anyone can verify — in weeks, not quarters.</p>
      <div class="btn-row" style="margin-top:1.4rem">
        <a class="btn btn-primary" href="/pricing/">Scope a pilot</a>
        <a class="btn btn-ghost" href="/playground/">Open the working demo</a>
      </div>
    </div>
  </section>

  <script>
    import "../islands/tamper-band.ts";
  </script>
</BaseLayout>
