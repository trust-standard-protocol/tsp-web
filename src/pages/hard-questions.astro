---
import BaseLayout from "../layouts/BaseLayout.astro";
import en from "../i18n/en.json";

// Hard questions — i18n EN (server) → NO (island). Q1 heading reworded (polish
// #10) and the public hash-store renamed from "manifest" to "register" (fix #2).
const hq = en.hardq;
---
<BaseLayout
  title="Hard Questions"
  description="The objections a serious reviewer asks first — privacy, forgery, governance — answered honestly, with the threat model and residual risks in the open."
>
  <section class="section section--tight">
    <div class="container">
      <p class="eyebrow" data-i18n="hardq.kicker">{hq.kicker}</p>
      <h1 data-i18n="hardq.h1">{hq.h1}</h1>
      <p class="lede" data-i18n="hardq.lede">{hq.lede}</p>
    </div>
  </section>

  <section class="section--tight" style="padding-top:0">
    <div class="container stack-lg">
      <article>
        <p class="eyebrow" data-i18n="hardq.q1_eyebrow">{hq.q1_eyebrow}</p>
        <h2 data-i18n="hardq.q1_title">{hq.q1_title}</h2>
        <p data-i18n="hardq.q1_body">{hq.q1_body}</p>
        <div class="grid grid-3" style="margin-top:1.5rem">
          {hq.q1_cards.map((c, i) => (
            <div class="card"><h3 data-i18n={`hardq.q1_cards.${i}.title`}>{c.title}</h3><p class="muted" data-i18n={`hardq.q1_cards.${i}.body`}>{c.body}</p></div>
          ))}
        </div>
      </article>

      <article>
        <p class="eyebrow" data-i18n="hardq.q2_eyebrow">{hq.q2_eyebrow}</p>
        <h2 data-i18n="hardq.q2_title">{hq.q2_title}</h2>
        <p data-i18n="hardq.q2_body">{hq.q2_body}</p>
        <div class="grid grid-2" style="margin-top:1.5rem">
          {hq.attacks.map((a, i) => (
            <article class="card card--accent">
              <h3 style="font-size:1.05rem" data-i18n={`hardq.attacks.${i}.attack`}>{a.attack}</h3>
              <p class="muted" data-i18n={`hardq.attacks.${i}.stop`}>{a.stop}</p>
              <p class="mono muted" style="font-size:var(--fs-micro)" data-i18n={`hardq.attacks.${i}.residual`}>{a.residual}</p>
            </article>
          ))}
        </div>
        <p class="muted" style="margin-top:1rem; font-size:var(--fs-small)" data-i18n="hardq.disclosure">{hq.disclosure}</p>
      </article>

      <article>
        <p class="eyebrow" data-i18n="hardq.q3_eyebrow">{hq.q3_eyebrow}</p>
        <h2 data-i18n="hardq.q3_title">{hq.q3_title}</h2>
        <div class="grid grid-3" style="margin-top:1.5rem">
          {hq.harder.map((h, i) => (
            <article class="card"><h3 style="font-size:1.05rem" data-i18n={`hardq.harder.${i}.q`}>{h.q}</h3><p class="muted" data-i18n={`hardq.harder.${i}.a`}>{h.a}</p></article>
          ))}
        </div>
      </article>

      <article class="section--ground" style="border-radius:var(--radius-lg); padding:clamp(24px,4vw,40px)">
        <h2 data-i18n="hardq.pilot_title">{hq.pilot_title}</h2>
        <p style="color:var(--ink-inverse-muted); max-width:64ch" data-i18n="hardq.pilot_body">{hq.pilot_body}</p>
      </article>
    </div>
  </section>
</BaseLayout>
