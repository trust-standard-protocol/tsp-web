---
import BaseLayout from "../layouts/BaseLayout.astro";
import Boundary from "../components/Boundary.astro";
import en from "../i18n/en.json";

// Pricing — i18n EN (server) → NO (island). Official status is never a tier.
const pr = en.pricing;
const tierChips = ["chip--ok", "chip--copper", "chip--teal"];
const tierCtas = ["/verify/", "/playground/", "/tools/"];
---
<BaseLayout
  title="Pricing"
  description="Free to verify, priced to operate. Tiers and contact — official status is a governed grant, never a pricing tier."
>
  <section class="section section--tight">
    <div class="container">
      <p class="eyebrow" data-i18n="pricing.kicker">{pr.kicker}</p>
      <h1 data-i18n="pricing.h1">{pr.h1}</h1>
      <p class="lede" data-i18n="pricing.lede">{pr.lede}</p>
    </div>
  </section>

  <section class="section--tight" style="padding-top:0">
    <div class="container">
      <div class="grid grid-3">
        {pr.tiers.map((tier, i) => (
          <article class="card card--accent" style="display:flex; flex-direction:column; gap:0.6rem">
            <span class={`chip ${tierChips[i]}`} data-i18n={`pricing.tiers.${i}.name`}>{tier.name}</span>
            <p style="font-size:1.4rem; font-weight:600" data-i18n={`pricing.tiers.${i}.price`}>{tier.price}</p>
            <p class="muted" style="flex:1" data-i18n={`pricing.tiers.${i}.body`}>{tier.body}</p>
            <a class="btn btn-quiet" href={tierCtas[i]} data-i18n={`pricing.tiers.${i}.cta`}>{tier.cta}</a>
          </article>
        ))}
      </div>

      <div class="boundary" style="margin-top:2rem">
        <p><strong data-i18n="pricing.official_strong">{pr.official_strong}</strong><span data-i18n="pricing.official_body">{pr.official_body}</span></p>
      </div>

      <div style="margin-top:1.5rem"><Boundary compact /></div>
    </div>
  </section>
</BaseLayout>
