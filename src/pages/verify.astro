---
import BaseLayout from "../layouts/BaseLayout.astro";
import Boundary from "../components/Boundary.astro";
import Icon from "../components/Icon.astro";
import en from "../i18n/en.json";

// Verify — i18n EN (server) → NO (island). Island hooks (ids) are unchanged;
// only static copy carries data-i18n. The file-input label keeps its <input>
// child outside the swapped span so the island never destroys it.
const vf = en.verify;
---
<BaseLayout
  title="Verify a receipt"
  description="Re-run TSP verification in your browser against the issuer public key. Nothing is uploaded; change one byte and it fails."
>
  <section class="section section--tight">
    <div class="container">
      <p class="eyebrow" data-i18n="verify.kicker">{vf.kicker}</p>
      <h1 data-i18n="verify.h1">{vf.h1}</h1>
      <p class="lede" data-i18n="verify.lede">{vf.lede}</p>
    </div>
  </section>

  <section class="section--tight" style="padding-top:0">
    <div class="container">
      <div class="split split--verify">
        <div class="vf-input stack">
          <div class="panel panel--terminal">
            <div class="panel__head">
              <span class="proof__dots" aria-hidden="true"><span></span><span></span><span></span></span>
              <span class="mono">receipt.json</span>
              <span class="panel__head-meta">offline · in-browser</span>
            </div>
            <label class="visually-hidden" for="vf-envelope" data-i18n="verify.envelope_label">TrustEnvelope (JSON) — or a {"{ envelope, publicKey }"} bundle</label>
            <textarea id="vf-envelope" spellcheck="false" placeholder="Paste a TSP receipt JSON here…" data-i18n-placeholder="islands.verify.paste_placeholder"></textarea>
          </div>
          <div>
            <label for="vf-key" data-i18n="verify.key_label">{vf.key_label}</label>
            <textarea id="vf-key" style="min-height:120px" spellcheck="false" placeholder={'{ "kty":"OKP", "crv":"Ed25519", "x":"…" }'}></textarea>
          </div>
          <div class="btn-row">
            <button id="vf-verify" class="btn btn-primary" type="button" data-i18n="verify.btn_verify">{vf.btn_verify}</button>
            <button id="vf-sample" class="btn btn-quiet" type="button" data-i18n="verify.btn_sample">{vf.btn_sample}</button>
            <button id="vf-tamper" class="btn btn-ghost" type="button"><Icon name="bolt" size={15} weight={85} /><span data-i18n="verify.btn_tamper">{vf.btn_tamper}</span></button>
            <button id="vf-clear" class="btn btn-quiet" type="button" data-i18n="verify.btn_clear">{vf.btn_clear}</button>
            <label class="btn btn-quiet" for="vf-file" style="cursor:pointer; margin:0;">
              <span data-i18n="verify.btn_upload">{vf.btn_upload}</span>
              <input id="vf-file" type="file" accept="application/json,.json" class="visually-hidden" />
            </label>
          </div>
        </div>

        <div class="panel">
          <div class="panel__head"><span data-i18n="verify.result_label">{vf.result_label}</span></div>
          <div class="panel__body stack">
            <div id="vf-verdict" class="verdict" data-state="idle" role="status" aria-live="polite" aria-atomic="true" data-i18n="verify.result_idle">{vf.result_idle}</div>
            <div id="vf-checks" class="checks"></div>
            <p id="vf-warnings" class="muted mono" style="font-size:var(--fs-micro)" role="status" aria-live="polite"></p>
            <div>
              <h2 style="font-size:1.02rem; margin-bottom:0.5rem;" data-i18n="verify.not_title">{vf.not_title}</h2>
              <ul class="muted stack not-list" style="list-style:none; font-size:var(--fs-small);">
                {vf.not_items.map((item, i) => (
                  <li><Icon name="x" size={14} weight={100} /><span data-i18n={`verify.not_items.${i}`}>{item}</span></li>
                ))}
              </ul>
            </div>
            <Boundary compact />
            <p class="muted" style="font-size:var(--fs-small)"><a href="/playground/" data-i18n="verify.build_cta">{vf.build_cta}</a></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    import "../islands/verify-workbench.ts";
  </script>
</BaseLayout>
