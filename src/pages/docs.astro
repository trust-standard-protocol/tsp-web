---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
import en from "../i18n/en.json";

// Docs quickstart — i18n EN (server) → NO (island). Code samples stay verbatim;
// only the prose translates. Closing reframed: the free trail is local, public
// anchoring is the paid Seal layer (copy-fix #1).
const dc = en.docs;
const stepCode = [
  `tsp issuer init --name "Northbank" --scope lending.credit --jurisdiction EU --key ./keys/k2.pub.jwk`,
  `const payload = tsp.capture({ type: "credit.application", inputs, output, policyVersion: "v4.2" });`,
  `await tsp.seal(payload, { key: k2, prevHash: lastHead }); // Ed25519 + SHA-256`,
  `tsp manifest publish ./receipts --url https://northbank.example/tsp/manifest`,
  `tsp verify --manifest <url> --registry <url>`
];
---
<BaseLayout
  title="Docs"
  description="Quickstart for TSP: register an issuer, instrument a decision, seal and chain the receipt, publish, and verify — all with Ed25519."
>
  <section class="section section--tight">
    <div class="container">
      <p class="eyebrow" data-i18n="docs.kicker">{dc.kicker}</p>
      <h1 data-i18n="docs.h1">{dc.h1}</h1>
      <p class="lede" data-i18n="docs.lede">{dc.lede}</p>
      <p class="chip chip--copper" style="margin-top:0.75rem" data-i18n="docs.chip">{dc.chip}</p>
    </div>
  </section>

  <section class="section--tight" style="padding-top:0">
    <div class="container">
      <ol class="steps">
        {dc.steps.map((step, i) => (
          <li>
            <h2 style="font-size:1.05rem" data-i18n={`docs.steps.${i}.title`}>{step.title}</h2>
            <pre style="margin-top:0.5rem"><code>{stepCode[i]}</code></pre>
          </li>
        ))}
      </ol>
      <p class="muted" style="margin-top:1.5rem">
        <span data-i18n="docs.closing_a">{dc.closing_a}</span><a href="/seal/" data-i18n="docs.closing_seal">{dc.closing_seal}</a><span data-i18n="docs.closing_b">{dc.closing_b}</span><a href="/protocol/" data-i18n="docs.closing_spec">{dc.closing_spec}</a><span data-i18n="docs.closing_c">{dc.closing_c}</span><a href="/tools/" data-i18n="docs.closing_tools">{dc.closing_tools}</a><span data-i18n="docs.closing_d">{dc.closing_d}</span><a href="/verify/" data-i18n="docs.closing_verify">{dc.closing_verify}</a><span data-i18n="docs.closing_e">{dc.closing_e}</span>
      </p>
      <p class="mono muted" style="font-size:var(--fs-micro); margin-top:1rem">
        Packages: <span class="mono">{site.pkgScope}/*</span> · open layer {site.license.split(" + ")[0]}.
      </p>
    </div>
  </section>
</BaseLayout>
