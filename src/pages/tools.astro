---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
import en from "../i18n/en.json";

// Tools — i18n EN (server) → NO (island). Package names + code samples stay
// verbatim; roles/notes/prose translate. One signer, N verifier cores.
const tl = en.tools;
const cores = [
  { pkg: `${site.pkgScope}/sdk-js`, signer: true, noteKey: "tools.core_signer_note", note: tl.core_signer_note },
  { pkg: `${site.pkgScope}/sdk-web`, signer: false, noteKey: "tools.core_verifier_note", note: tl.core_verifier_note },
  { pkg: `${site.pkgScope}/sdk-python`, signer: false, noteKey: null, note: "" },
  { pkg: `${site.pkgScope}/sdk-go`, signer: false, noteKey: null, note: "" },
  { pkg: `${site.pkgScope}/sdk-rust`, signer: false, noteKey: null, note: "" },
  { pkg: `${site.pkgScope}/sdk-java`, signer: false, noteKey: null, note: "" },
  { pkg: `${site.pkgScope}/sdk-csharp`, signer: false, noteKey: null, note: "" }
];
const installCode = `npm i ${site.pkgScope}/sdk-web
import { verifyTrustEnvelopeV3 } from "${site.pkgScope}/sdk-web";`;
const mcpCode = `# verify a receipt from an agent loop, offline
tsp-mcp --proxy   # captures tool-call evidence; re-runs verification`;
---
<BaseLayout
  title="Tools"
  description="Operationalize the evidence: verifier cores (one signer, N verifiers), an open MCP server/proxy, TrustBadge, and licensed operator modules."
>
  <section class="section section--tight">
    <div class="container">
      <p class="eyebrow" data-i18n="tools.kicker">{tl.kicker}</p>
      <h1 data-i18n="tools.h1">{tl.h1}</h1>
      <p class="lede" data-i18n="tools.lede">{tl.lede}</p>
    </div>
  </section>

  <section class="section--tight" style="padding-top:0">
    <div class="container">
      <h2 data-i18n="tools.cores_title">{tl.cores_title}</h2>
      <p class="lede" data-i18n="tools.cores_lede">{tl.cores_lede}</p>
      <div class="grid grid-3" style="margin-top:1.5rem">
        {cores.map((core) => (
          <article class="card">
            <p class="mono" style="font-size:var(--fs-mono); word-break:normal; overflow-wrap:anywhere">{core.pkg}</p>
            <span class={core.signer ? "chip chip--copper" : "chip chip--teal"} data-i18n={core.signer ? "tools.core_signer" : "tools.core_verifier"}>{core.signer ? tl.core_signer : tl.core_verifier}</span>
            {core.noteKey && <p class="muted" style="font-size:var(--fs-small); margin-top:0.5rem" data-i18n={core.noteKey}>{core.note}</p>}
          </article>
        ))}
      </div>
      <pre style="margin-top:1.5rem"><code>{installCode}</code></pre>
    </div>
  </section>

  <section class="section--tight section--paper-deep">
    <div class="container">
      <h2 data-i18n="tools.mcp_title">{tl.mcp_title}</h2>
      <p class="lede" data-i18n="tools.mcp_lede">{tl.mcp_lede}</p>
      <pre style="margin-top:1rem"><code>{mcpCode}</code></pre>
    </div>
  </section>

  <section class="section--tight">
    <div class="container">
      <h2 data-i18n="tools.modules_title">{tl.modules_title}</h2>
      <p class="lede" data-i18n="tools.modules_lede">{tl.modules_lede}</p>
      <div class="grid grid-3" style="margin-top:1.5rem">
        {tl.modules.map((mod, i) => (
          <article class="card card--accent">
            <h3 data-i18n={`tools.modules.${i}.name`}>{mod.name}</h3>
            <p class="muted" data-i18n={`tools.modules.${i}.body`}>{mod.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section--tight section--paper-deep">
    <div class="container">
      <h2 data-i18n="tools.badge_title">{tl.badge_title}</h2>
      <p class="lede" data-i18n="tools.badge_lede">{tl.badge_lede}</p>
      <p style="margin-top:1rem"><a class="btn btn-ghost" href="/playground/" data-i18n="tools.badge_cta">{tl.badge_cta}</a></p>
    </div>
  </section>

  <section class="section--tight">
    <div class="container">
      <h2 data-i18n="tools.sec_title">{tl.sec_title}</h2>
      <ul class="stack muted" style="list-style:none">
        {tl.sec_points.map((pt, i) => (
          <li>· <span data-i18n={`tools.sec_points.${i}`}>{pt}</span></li>
        ))}
      </ul>
      <p style="margin-top:1rem" class="muted" data-i18n="tools.sec_note">{tl.sec_note}</p>
    </div>
  </section>
</BaseLayout>
