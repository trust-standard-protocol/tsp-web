---
// The honest boundary line, reusable across pages. The doctrine, stated as a
// negation — the opposite of an overclaim. Carved out of the claim scan by design.
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---
<aside class="boundary" role="note" aria-label="What TSP does and does not mean">
  {compact ? (
    <p>
      TSP makes your AI evidence <strong>durable, tamper-evident, and verifiable offline</strong>.
      It does <strong>not</strong> make you compliant, prove your model is correct, or confer official status.
    </p>
  ) : (
    <p>
      TSP makes your AI evidence <strong>durable, tamper-evident, and verifiable offline</strong> — by anyone,
      without trusting the vendor. It does <strong>not</strong> make you compliant, prove your model is right or
      safe, or confer official status. Verification reports the <strong>integrity</strong> of the evidence, never a
      legal verdict. That call stays with your DPA and counsel.
    </p>
  )}
</aside>
