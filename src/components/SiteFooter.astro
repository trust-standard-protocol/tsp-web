---
import { footerGroups, site } from "../data/site";
import { t } from "../i18n";
---
<footer class="site-footer" id="docs">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a class="wordmark" href="/" aria-label={`${site.name} — home`}>
          <img src="/tsp-logo-light.png" alt="" class="footer-logo" width="200" height="147" />
        </a>
        <p data-i18n="footer.blurb">{t("en", "footer.blurb")}</p>
        <p class="lang-draft-note" lang="no">Norsk er et lanseringsutkast — venter på korrekturlesing av en innfødt taler (Bokmål).</p>
      </div>
      {footerGroups.map((group) => (
        <nav class="footer-col" aria-label={group.title}>
          <h2 data-i18n={group.i18n}>{group.title}</h2>
          <ul>
            {group.links.map((link) => (
              <li><a href={link.href} data-i18n={link.i18n}>{link.label}</a></li>
            ))}
          </ul>
        </nav>
      ))}
    </div>
    <div class="legal-bar">
      <p data-i18n="footer.legal">{t("en", "footer.legal")}</p>
      <p class="legal-bar__disclaimer" data-i18n="footer.disclaimer">{t("en", "footer.disclaimer")}</p>
    </div>
  </div>
</footer>
