---
// The TSP wordmark glyph (brand pack 5): a rounded square with the "TSP"
// monogram and a single amber node — the sealed decision receipt, in miniature.
// Colors come from CSS custom properties so the footer (dark) can recolor it
// without a second SVG. Used inline in the header/footer and echoed by the favicon.
interface Props {
  size?: number;
  title?: string;
}
const { size = 34, title = "Trust Standard Protocol" } = Astro.props;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 64 64"
  role="img"
  aria-label={title}
  class="seal-mark"
  xmlns="http://www.w3.org/2000/svg"
>
  <rect
    x="5" y="5" width="54" height="54" rx="16"
    fill="var(--seal-fill, var(--tsp-surface, #faf8f1))"
    stroke="var(--seal-stroke, var(--tsp-accent, #1d3a5f))"
    stroke-width="3.5"
  />
  <text
    x="32" y="33"
    text-anchor="middle" dominant-baseline="central"
    font-family="'IBM Plex Sans', system-ui, sans-serif"
    font-size="22" font-weight="700"
    fill="var(--seal-text, var(--tsp-ink, #1a1815))"
  >TSP</text>
  <circle cx="54" cy="10" r="5.5" fill="var(--seal-dot, var(--tsp-amber, #9c5a2e))" />
</svg>
