---
// The TSP square seal mark. Concentric seal + an Ed25519/ledger "check" stroke.
// Self-contained colors so it works inline, as a favicon, and in OG images.
interface Props {
  size?: number;
  title?: string;
}
const { size = 30, title = "Trust Standard Protocol" } = Astro.props;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 64 64"
  role="img"
  aria-label={title}
  class="seal-mark"
  xmlns="http://www.w3.org/2000/svg"
>
  <rect x="2" y="2" width="60" height="60" rx="13" fill="#15403d" />
  <rect x="10.5" y="10.5" width="43" height="43" rx="8.5" fill="none" stroke="#d99a5e" stroke-width="1.4" opacity="0.55" />
  <path
    d="M19 33.5 L28.5 43 L46 22.5"
    fill="none"
    stroke="#9c5a2e"
    stroke-width="5"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
  <circle cx="46" cy="22.5" r="2.6" fill="#e0a45e" />
</svg>
